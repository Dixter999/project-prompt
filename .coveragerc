[run]
source = src
omit = 
    **/__init__.py
    **/tests/**
    **/conftest.py
    **/integrations/anthropic_advanced.py
    **/integrations/__pycache__/**
    **/integrations/*_integration.py
    **/utils/__pycache__/**
    **/analyzers/__pycache__/**

[report]
show_missing = true
skip_covered = true
fail_under = 80
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    pass
    raise ImportError
    raise NotImplemented
    @abstractmethod
    @property
    @staticmethod
    @classmethod

[html]
directory = htmlcov
debug = info

[xml]
output = coverage.xml
