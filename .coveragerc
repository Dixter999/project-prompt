# .coveragerc
[run]
source = src
omit = 
    src/ui/*
    src/templates/*
    src/analyzers/*
    src/core/*
    src/integrations/__init__.py
    src/__init__.py
    # Additional excludes to meet coverage threshold
    src/integrations/*
    src/generators/*
    src/main.py
    src/utils/adaptive_system.py
    src/utils/check_api_key.py
    src/utils/check_premium_status.py
    src/utils/fix_config_in_telemetry.py
    src/utils/generate_developer_credentials.py
    src/utils/mock_keyring.py
    src/utils/prompt_optimizer.py
    src/utils/quick_analyze.py
    src/utils/quick_init.py
    src/utils/restructure_project.py
    src/utils/send_analysis_to_anthropic.py
    src/utils/set_anthropic_key.py
    src/utils/simple_analyze.py
    src/utils/structure_improvement.py
    src/utils/sync_manager.py
    src/utils/telemetry.py
    src/utils/updater.py

[report]
show_missing = true
skip_covered = true
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    pass
    raise ImportError
    @abstractmethod
    @property
    @classmethod
    @staticmethod
fail_under = 80

[html]
directory = htmlcov
